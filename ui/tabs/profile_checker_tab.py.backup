import customtkinter as ctk
import threading
import time
import csv
import os
from datetime import datetime
from tkinter import filedialog, messagebox

from core.api.whatsapp_baileys import BaileysAPI
from core.utils.contacts import load_contacts_from_csv, normalize_phone
from ui.utils.threading_helpers import start_daemon, ui_dispatch
from ui.theme import (
    COLORS,
    SPACING,
    TYPOGRAPHY,
    TabHeader,
    StatusBadge,
    heading,
    body,
    SectionCard,
    StatCard,
    PrimaryButton,
    SecondaryButton,
    StyledInput,
    StyledTextbox,
    apply_leadwave_theme,
)

class ProfileCheckerTab(ctk.CTkFrame):
    """Profile Checker PRO - Validate WhatsApp numbers availability."""

    def __init__(self, master):
        super().__init__(master, fg_color="transparent")
        
        self.api = BaileysAPI()
        self.contacts = []
        self.checked_results = []
        self.log_history = []
        self.is_running = False
        self.stop_event = threading.Event()
        
        self.stats = {
            "total": 0,
            "checked": 0,
            "active": 0,
            "inactive": 0,
            "error": 0
        }
        
        self._build_ui()
        apply_leadwave_theme(self)
        start_daemon(self._load_accounts)

    def _build_ui(self):
        header = TabHeader(
            self,
            title="Profile Checker PRO",
            subtitle="Validate WhatsApp availability in bulk",
        )
        header.pack(fill="x", padx=SPACING["md"], pady=(SPACING["sm"], SPACING["xs"]))

        self.status_badge = StatusBadge(header.actions, text="READY", tone="info")
        self.status_badge.pack(side="right")

        # Main Grid
        main = ctk.CTkFrame(self, fg_color="transparent")
        main.pack(fill="both", expand=True, padx=SPACING["md"], pady=(0, SPACING["md"]))
        main.grid_columnconfigure(0, weight=1)
        main.grid_columnconfigure(1, weight=1)
        main.grid_rowconfigure(0, weight=1)

        # --- Left Column ---
        left_col = ctk.CTkFrame(main, fg_color="transparent")
        left_col.grid(row=0, column=0, sticky="nsew", padx=(0, SPACING["xs"]))
        left_col.grid_rowconfigure(3, weight=1)
        
        # Settings
        settings_card = SectionCard(left_col)
        settings_card.pack(fill="x", pady=(0, SPACING["sm"]))
        ctk.CTkLabel(settings_card.inner_frame, text="Configuration", font=heading(TYPOGRAPHY["h3"], "bold")).pack(anchor="w", pady=(0, SPACING["sm"]))
        
        ctk.CTkLabel(settings_card.inner_frame, text="Select Account", font=body(TYPOGRAPHY["caption"], "bold")).pack(anchor="w", pady=(0, 4))
        self.account_dropdown = ctk.CTkComboBox(settings_card.inner_frame, values=["acc1"], width=200)
        self.account_dropdown.pack(fill="x", pady=(0, SPACING["sm"]))

        # Single Check
        single_card = SectionCard(left_col)
        single_card.pack(fill="x", pady=(0, SPACING["sm"]))
        ctk.CTkLabel(single_card.inner_frame, text="Single Number Check", font=heading(TYPOGRAPHY["h3"], "bold")).pack(anchor="w", pady=(0, SPACING["sm"]))
        
        self.single_input = StyledInput(single_card.inner_frame, placeholder_text="+880...")
        self.single_input.pack(fill="x", pady=(0, SPACING["xs"]))
        
        single_btn_row = ctk.CTkFrame(single_card.inner_frame, fg_color="transparent")
        single_btn_row.pack(fill="x")
        SecondaryButton(single_btn_row, text="Check Now", command=self.check_single).pack(side="left")
        self.single_result = ctk.CTkLabel(single_btn_row, text="", font=body(TYPOGRAPHY["caption"]), text_color=COLORS["text_muted"])
        self.single_result.pack(side="left", padx=SPACING["sm"])

        # Bulk Check
        bulk_card = SectionCard(left_col)
        bulk_card.pack(fill="x")
        ctk.CTkLabel(bulk_card.inner_frame, text="Bulk Check", font=heading(TYPOGRAPHY["h3"], "bold")).pack(anchor="w", pady=(0, SPACING["sm"]))
        
        # Add button to extract chat list numbers
        SecondaryButton(bulk_card.inner_frame, text="Extract Chat List Numbers", command=self.extract_chat_list_numbers).pack(fill="x", pady=(0, SPACING["xs"]))
        
        SecondaryButton(bulk_card.inner_frame, text="Upload CSV", command=self.load_csv).pack(fill="x", pady=(0, SPACING["xs"]))
        self.file_label = ctk.CTkLabel(bulk_card.inner_frame, text="No file selected", font=body(TYPOGRAPHY["caption"]), text_color=COLORS["text_muted"])
        self.file_label.pack(anchor="w", pady=(0, SPACING["sm"]))
        
        self.start_btn = PrimaryButton(bulk_card.inner_frame, text="Start Bulk Check", command=self.start_bulk)
        self.start_btn.pack(fill="x", pady=(0, SPACING["xs"]))
        
        self.stop_btn = SecondaryButton(bulk_card.inner_frame, text="Stop", command=self.stop_bulk, state="disabled", fg_color=COLORS["danger"], text_color=COLORS["text_inverse"])
        self.stop_btn.pack(fill="x")

        # --- Right Column ---
        right_col = ctk.CTkFrame(main, fg_color="transparent")
        right_col.grid(row=0, column=1, sticky="nsew", padx=(SPACING["xs"], 0))
        right_col.grid_rowconfigure(2, weight=1)

        # Stats
        stats_card = SectionCard(right_col)
        stats_card.pack(fill="x", pady=(0, SPACING["sm"]))
        ctk.CTkLabel(stats_card.inner_frame, text="Statistics", font=heading(TYPOGRAPHY["h3"], "bold")).pack(anchor="w", pady=(0, SPACING["sm"]))
        
        stats_grid = ctk.CTkFrame(stats_card.inner_frame, fg_color="transparent")
        stats_grid.pack(fill="x", pady=(0, SPACING["xs"]))
        stats_grid.grid_columnconfigure((0,1), weight=1)
        
        self.stat_total = StatCard(stats_grid, "Total", "0", "info")
        self.stat_total.grid(row=0, column=0, sticky="ew", padx=(0, 4))
        self.stat_checked = StatCard(stats_grid, "Checked", "0", "neutral")
        self.stat_checked.grid(row=0, column=1, sticky="ew", padx=(4, 0))
        
        stats_grid2 = ctk.CTkFrame(stats_card.inner_frame, fg_color="transparent")
        stats_grid2.pack(fill="x")
        stats_grid2.grid_columnconfigure((0,1), weight=1)
        
        self.stat_active = StatCard(stats_grid2, "Active", "0", "success")
        self.stat_active.grid(row=0, column=0, sticky="ew", padx=(0, 4), pady=(8, 0))
        self.stat_inactive = StatCard(stats_grid2, "Inactive", "0", "danger")
        self.stat_inactive.grid(row=0, column=1, sticky="ew", padx=(4, 0), pady=(8, 0))

        self.progress = ctk.CTkProgressBar(stats_card.inner_frame, height=10)
        self.progress.pack(fill="x", pady=(SPACING["md"], 0))
        self.progress.set(0)

        # Logs
        log_card = SectionCard(right_col)
        log_card.pack(fill="both", expand=True)
        
        log_header = ctk.CTkFrame(log_card.inner_frame, fg_color="transparent")
        log_header.pack(fill="x", pady=(0, SPACING["xs"]))
        ctk.CTkLabel(log_header, text="Results Log", font=heading(TYPOGRAPHY["h3"], "bold")).pack(side="left")
        
        self.filter_var = ctk.StringVar(value="All")
        ctk.CTkOptionMenu(
            log_header,
            values=["All", "Active", "Inactive", "Error"],
            variable=self.filter_var,
            command=self._apply_filter,
            width=100,
            height=24
        ).pack(side="right", padx=(SPACING["xs"], 0))

        SecondaryButton(log_header, text="Export", command=self.export_results, width=80, height=24).pack(side="right", padx=(SPACING["xs"], 0))
        SecondaryButton(log_header, text="Clear", command=self._clear_log, width=60, height=24).pack(side="right")
        
        self.log_box = StyledTextbox(log_card.inner_frame, font=(TYPOGRAPHY["mono"], 12))
        self.log_box.pack(fill="both", expand=True)

    def _load_accounts(self):
        result = self.api.get_accounts()
        if not result.get("ok"):
            return

        accounts = [item.get("account") for item in result.get("accounts", []) if item.get("account")]
        if not accounts:
            return

        self.account_dropdown.configure(values=accounts)
        self.account_dropdown.set(result.get("current_account") or accounts[0])

    def _log(self, message, status=None):
        timestamp = datetime.now().strftime("%H:%M:%S")
        self.log_history.append({"ts": timestamp, "msg": message, "status": status})
        
        current_filter = self.filter_var.get().lower()
        if current_filter == "all" or (status and status.lower() == current_filter):
            ui_dispatch(self, lambda: self.log_box.insert("end", f"[{timestamp}] {message}\n"))
            ui_dispatch(self, lambda: self.log_box.see("end"))

    def _apply_filter(self, choice):
        self.log_box.delete("1.0", "end")
        filter_val = choice.lower()
        
        for entry in self.log_history:
            status = entry.get("status")
            if filter_val == "all" or (status and status.lower() == filter_val):
                self.log_box.insert("end", f"[{entry['ts']}] {entry['msg']}\n")
        self.log_box.see("end")

    def _clear_log(self):
        self.log_history = []
        self.log_box.configure(state="normal")
        self.log_box.delete("1.0", "end")
        self.log_box.configure(state="disabled")

    def check_single(self):
        number = self.single_input.get().strip()
        if not number:
            self.single_result.configure(text="Enter number", text_color=COLORS["danger"])
            return
        
        account = self.account_dropdown.get()
        self.single_result.configure(text="Checking...", text_color=COLORS["text_muted"])
        
        def _work():
            res = self.api.profile_check(number, account=account)
            if not res.get("ok"):
                ui_dispatch(self, lambda: self.single_result.configure(text="Error", text_color=COLORS["danger"]))
                return
            
            exists = res.get("exists")
            text = "Active on WhatsApp" if exists else "Not on WhatsApp"
            color = COLORS["success"] if exists else COLORS["danger"]
            ui_dispatch(self, lambda: self.single_result.configure(text=text, text_color=color))
            
        start_daemon(_work)

    def load_csv(self):
        file_path = filedialog.askopenfilename(filetypes=[("CSV Files", "*.csv")])
        if not file_path:
            return
            
        try:
            normalized = load_contacts_from_csv(file_path)
            self.contacts = [{"phone": c.phone, "name": c.name} for c in normalized]
            self.file_label.configure(text=f"Loaded {len(self.contacts)} contacts")
            self.stat_total.set_value(str(len(self.contacts)))
            self._log(f"Loaded {len(self.contacts)} contacts from CSV")
        except Exception as e:
            messagebox.showerror("Error", f"Failed to load CSV: {e}")

    def start_bulk(self):
        if not self.contacts:
            messagebox.showwarning("Warning", "Please load contacts first")
            return
        
        self.is_running = True
        self.stop_event.clear()
        self.checked_results = []
        self.stats = {k: 0 for k in self.stats}
        self.stats["total"] = len(self.contacts)
        
        self.start_btn.configure(state="disabled")
        self.stop_btn.configure(state="normal")
        self.status_badge.set_text("RUNNING", tone="warning")
        
        start_daemon(self._bulk_worker)

    def stop_bulk(self):
        self.is_running = False
        self.stop_event.set()
        self.start_btn.configure(state="normal")
        self.stop_btn.configure(state="disabled")
        self.status_badge.set_text("STOPPED", tone="neutral")
        self._log("Bulk check stopped by user")

    def _bulk_worker(self):
        account = self.account_dropdown.get()
        
        for i, contact in enumerate(self.contacts):
            if self.stop_event.is_set():
                break
                
            phone = contact.get("phone")
            res = self.api.profile_check(phone, account=account)
            
            status = "error"
            if res.get("ok"):
                status = "active" if res.get("exists") else "inactive"
            
            self.stats["checked"] += 1
            if status == "active":
                self.stats["active"] += 1
            elif status == "inactive":
                self.stats["inactive"] += 1
            else:
                self.stats["error"] += 1
                
            self.checked_results.append({**contact, "status": status})
            
            # Update UI
            progress = (i + 1) / len(self.contacts)
            ui_dispatch(self, lambda: self.progress.set(progress))
            ui_dispatch(self, self._update_stats_ui)
            ui_dispatch(self, lambda p=phone, s=status: self._log(f"{p}: {s.upper()}", status=s))
            
            # Rate limit
            time.sleep(0.5)
            
        self.is_running = False
        ui_dispatch(self, lambda: self.start_btn.configure(state="normal"))
        ui_dispatch(self, lambda: self.stop_btn.configure(state="disabled"))
        ui_dispatch(self, lambda: self.status_badge.set_text("COMPLETED", tone="success"))

    def _update_stats_ui(self):
        self.stat_checked.set_value(str(self.stats["checked"]))
        self.stat_active.set_value(str(self.stats["active"]))
        self.stat_inactive.set_value(str(self.stats["inactive"]))

    def extract_chat_list_numbers(self):
        """
        PRO Feature: Extract phone numbers from WhatsApp chat list and save to CSV.
        This advanced function allows grabbing WhatsApp account numbers with one click,
        with comprehensive metadata extraction and intelligent processing.
        """
        account = self.account_dropdown.get()
        if not account:
            messagebox.showwarning("Warning", "Please select an account first")
            return
            
        # Disable UI elements during extraction to prevent multiple operations
        self.start_btn.configure(state="disabled")
        
        self.status_badge.set_text("EXTRACTING", tone="warning")
        self._log(f"PRO Extraction: Initializing chat list extraction from account: {account}", status="info")
        
        def _worker():
            try:
                # Connection verification with retry mechanism
                self._log("PRO Extraction: Verifying WhatsApp connection...", status="info")
                retry_count = 0
                max_retries = 2
                
                while retry_count <= max_retries:
                    health_check = self.api.health_check()
                    if health_check[0]:
                        self._log("PRO Extraction: Connection verified successfully", status="success")
                        break
                        
                    retry_count += 1
                    if retry_count <= max_retries:
                        ui_dispatch(self, lambda: self._log(f"PRO Extraction: Connection issue, retrying ({retry_count}/{max_retries})...", status="warning"))
                        time.sleep(1)  # Wait before retry
                    else:
                        ui_dispatch(self, lambda: messagebox.showerror("Connection Error", f"WhatsApp connection issue: {health_check[1]}"))
                        ui_dispatch(self, lambda: self.status_badge.set_text("CONNECTION ERROR", tone="danger"))
                        ui_dispatch(self, lambda: self._log(f"PRO Extraction: Connection error - {health_check[1]}", status="error"))
                        ui_dispatch(self, lambda: self.start_btn.configure(state="normal"))
                        return
                
                # Get chat list from WhatsApp API with progress updates
                self._log("PRO Extraction: Fetching chat list data...", status="info")
                ui_dispatch(self, lambda: self.progress.set(0.1))
                
                result = self.api.get_chat_list(account=account)
                ui_dispatch(self, lambda: self.progress.set(0.3))
                
                if not result.get("ok"):
                    error_msg = result.get("error", "Unknown error")
                    error_code = result.get("code", "UNKNOWN_ERROR")
                    ui_dispatch(self, lambda: messagebox.showerror("API Error", f"Failed to get chat list: {error_msg} (Code: {error_code})"))
                    ui_dispatch(self, lambda: self.status_badge.set_text("API ERROR", tone="danger"))
                    ui_dispatch(self, lambda: self._log(f"PRO Extraction: API error - {error_msg} (Code: {error_code})", status="error"))
                    ui_dispatch(self, lambda: self.start_btn.configure(state="normal"))
                    return
                
                # Extract contacts from chat list with detailed metadata
                self._log("PRO Extraction: Processing chat data...", status="info")
                ui_dispatch(self, lambda: self.progress.set(0.5))
                
                chats = result.get("chats", [])
                total_chats = len(chats)
                self._log(f"PRO Extraction: Found {total_chats} chats to process", status="info")
                
                extracted_contacts = []
                processed = 0
                
                for chat in chats:
                    # Extract phone number from chat ID (format: 123456789@s.whatsapp.net or @c.us)
                    chat_id = chat.get("id", "")
                    if "@s.whatsapp.net" in chat_id or "@c.us" in chat_id:
                        phone = chat_id.split("@")[0]
                        # Normalize phone number with advanced validation
                        normalized_phone = normalize_phone(phone)
                        if normalized_phone:
                            # Enhanced metadata extraction
                            name = chat.get("name", "") or chat.get("pushname", "") or "Unknown"
                            last_message_time = chat.get("t", 0)
                            unread_count = chat.get("count", 0)
                            
                            # Create contact with rich metadata
                            contact_data = {
                                "phone": normalized_phone,
                                "name": name,
                                "status": "active",  # All contacts from chat list are active
                                "last_activity": last_message_time,
                                "unread": unread_count
                            }
                            
                            # Add additional metadata if available
                            if chat.get("isGroup"):
                                contact_data["type"] = "group"
                            else:
                                contact_data["type"] = "individual"
                                
                            extracted_contacts.append(contact_data)
                    
                    # Update progress
                    processed += 1
                    if processed % 5 == 0 or processed == total_chats:
                        progress = 0.5 + (0.3 * (processed / total_chats))
                        ui_dispatch(self, lambda p=progress: self.progress.set(p))
                
                if not extracted_contacts:
                    ui_dispatch(self, lambda: messagebox.showinfo("Info", "No contacts found in chat list"))
                    ui_dispatch(self, lambda: self.status_badge.set_text("COMPLETED", tone="info"))
                    ui_dispatch(self, lambda: self._log("PRO Extraction: No contacts found in chat list", status="info"))
                    ui_dispatch(self, lambda: self.start_btn.configure(state="normal"))
                    ui_dispatch(self, lambda: self.progress.set(0))
                    return
                
                # Process and categorize contacts
                self._log(f"PRO Extraction: Successfully extracted {len(extracted_contacts)} contacts", status="success")
                self._log("PRO Extraction: Preparing data for export...", status="info")
                ui_dispatch(self, lambda: self.progress.set(0.85))
                
                # Sort contacts by last activity
                extracted_contacts.sort(key=lambda x: x.get("last_activity", 0), reverse=True)
                
                # Save to CSV with enhanced metadata
                ui_dispatch(self, lambda: self._save_chat_list_to_csv(extracted_contacts))
                
            except Exception as e:
                import traceback
                error_details = traceback.format_exc()
                ui_dispatch(self, lambda: messagebox.showerror("Error", f"Failed to extract chat list: {e}"))
                ui_dispatch(self, lambda: self.status_badge.set_text("ERROR", tone="danger"))
                ui_dispatch(self, lambda: self._log(f"PRO Extraction Error: {str(e)}", status="error"))
                ui_dispatch(self, lambda: self._log(f"Error details: {error_details}", status="error"))
                ui_dispatch(self, lambda: self.start_btn.configure(state="normal"))
                ui_dispatch(self, lambda: self.progress.set(0))
        
        start_daemon(_worker)
    
    def _save_chat_list_to_csv(self, contacts):
        """
        PRO CSV Export: Save extracted chat list contacts to CSV file
        with advanced metadata and formatting options
        """
        if not contacts:
            self.start_btn.configure(state="normal")
            self.progress.set(0)
            return
        
        # Prepare export options dialog
        export_window = ctk.CTkToplevel(self)
        export_window.title("PRO Export Options")
        export_window.geometry("400x300")
        export_window.resizable(False, False)
        export_window.grab_set()  # Make window modal
        
        # Center the window
        export_window.update_idletasks()
        width = export_window.winfo_width()
        height = export_window.winfo_height()
        x = (export_window.winfo_screenwidth() // 2) - (width // 2)
        y = (export_window.winfo_screenheight() // 2) - (height // 2)
        export_window.geometry(f"{width}x{height}+{x}+{y}")
        
        # Export options with PRO styling
        title_label = ctk.CTkLabel(export_window, text="PRO Export Options", font=(TYPOGRAPHY["heading"], 18, "bold"))
        title_label.pack(pady=(15, 5))
        
        subtitle_label = ctk.CTkLabel(
            export_window, 
            text="Configure your export preferences",
            text_color=COLORS["text_secondary"],
            font=(TYPOGRAPHY["body"], 12)
        )
        subtitle_label.pack(pady=(0, 15))
        
        # File format options
        format_frame = ctk.CTkFrame(export_window)
        format_frame.pack(fill="x", padx=20, pady=10)
        
        ctk.CTkLabel(
            format_frame, 
            text="Export Format:", 
            font=(TYPOGRAPHY["body"], 13, "bold")
        ).pack(anchor="w", padx=10, pady=(10, 0))
        
        format_var = ctk.StringVar(value="standard")
        ctk.CTkRadioButton(
            format_frame, 
            text="Standard Format (Compatible with all tabs)", 
            variable=format_var, 
            value="standard",
            font=(TYPOGRAPHY["body"], 12)
        ).pack(anchor="w", padx=20, pady=(5, 0))
        
        ctk.CTkRadioButton(
            format_frame, 
            text="Enhanced Format (With additional metadata)", 
            variable=format_var, 
            value="enhanced",
            font=(TYPOGRAPHY["body"], 12)
        ).pack(anchor="w", padx=20, pady=(5, 10))
        
        # Filter options
        filter_frame = ctk.CTkFrame(export_window)
        filter_frame.pack(fill="x", padx=20, pady=10)
        
        ctk.CTkLabel(
            filter_frame, 
            text="Filter Options:", 
            font=(TYPOGRAPHY["body"], 13, "bold")
        ).pack(anchor="w", padx=10, pady=(10, 0))
        
        include_groups_var = ctk.BooleanVar(value=True)
        ctk.CTkCheckBox(
            filter_frame, 
            text="Include Groups", 
            variable=include_groups_var,
            font=(TYPOGRAPHY["body"], 12)
        ).pack(anchor="w", padx=20, pady=(5, 0))
        
        # Add sorting option
        sort_var = ctk.StringVar(value="activity")
        ctk.CTkLabel(
            filter_frame, 
            text="Sort By:", 
            font=(TYPOGRAPHY["body"], 13, "bold")
        ).pack(anchor="w", padx=10, pady=(10, 0))
        
        ctk.CTkRadioButton(
            filter_frame, 
            text="Last Activity (Recent first)", 
            variable=sort_var, 
            value="activity",
            font=(TYPOGRAPHY["body"], 12)
        ).pack(anchor="w", padx=20, pady=(5, 0))
        
        ctk.CTkRadioButton(
            filter_frame, 
            text="Name (Alphabetical)", 
            variable=sort_var, 
            value="name",
            font=(TYPOGRAPHY["body"], 12)
        ).pack(anchor="w", padx=20, pady=(5, 10))
        
        # Buttons
        button_frame = ctk.CTkFrame(export_window, fg_color="transparent")
        button_frame.pack(fill="x", padx=20, pady=(20, 10))
        
        def on_cancel():
            export_window.destroy()
            self.status_badge.set_text("CANCELLED", tone="neutral")
            self._log("PRO Extraction: CSV export cancelled by user", status="info")
            self.start_btn.configure(state="normal")
            self.progress.set(0)
        
        def on_export():
            export_format = format_var.get()
            include_groups = include_groups_var.get()
            sort_by = sort_var.get()
            
            # Filter contacts based on options
            filtered_contacts = contacts
            if not include_groups:
                filtered_contacts = [c for c in contacts if c.get("type") != "group"]
            
            # Sort contacts based on selected option
            if sort_by == "activity":
                filtered_contacts.sort(key=lambda x: x.get("last_activity", 0), reverse=True)
            elif sort_by == "name":
                filtered_contacts.sort(key=lambda x: x.get("name", "").lower())
            
            export_window.destroy()
            self._perform_csv_export(filtered_contacts, export_format)
        
        ctk.CTkButton(button_frame, text="Cancel", command=on_cancel).pack(side="left", padx=(0, 10))
        ctk.CTkButton(button_frame, text="Export", command=on_export).pack(side="right")
    
    def _perform_csv_export(self, contacts, export_format="standard"):
        """Perform the actual CSV export with the selected options"""
        # Ask user for save location
        path = filedialog.asksaveasfilename(
            defaultextension=".csv",
            filetypes=[("CSV Files", "*.csv")],
            title="Save Chat List Numbers"
        )
        
        if not path:
            self.status_badge.set_text("CANCELLED", tone="neutral")
            self._log("PRO Extraction: CSV export cancelled by user", status="info")
            self.start_btn.configure(state="normal")
            self.progress.set(0)
            return
            
        try:
            # Determine fields based on format
            if export_format == "standard":
                fieldnames = ["phone", "name", "status"]
                # Create standard format contacts
                export_contacts = [{k: c[k] for k in fieldnames} for c in contacts]
            else:
                # Enhanced format with all metadata
                fieldnames = ["phone", "name", "status", "type", "last_activity", "unread"]
                export_contacts = contacts
            
            # Write contacts to CSV
            with open(path, 'w', newline='', encoding='utf-8') as f:
                writer = csv.DictWriter(f, fieldnames=fieldnames)
                writer.writeheader()
                writer.writerows(export_contacts)
            
            # Update UI with standard format contacts for compatibility
            standard_contacts = [{k: c[k] for k in ["phone", "name", "status"]} for c in contacts]
            self.contacts = [{"phone": c["phone"], "name": c["name"]} for c in standard_contacts]
            self.checked_results = standard_contacts
            self.file_label.configure(text=f"Loaded {len(contacts)} contacts from chat list")
            self.stat_total.set_value(str(len(contacts)))
            self.stat_active.set_value(str(len(contacts)))
            
            # Final progress and status updates
            self.progress.set(1.0)
            self.status_badge.set_text("COMPLETED", tone="success")
            self._log(f"PRO Extraction: Successfully exported {len(contacts)} contacts to CSV", status="success")
            messagebox.showinfo("Success", f"Successfully extracted and exported {len(contacts)} contacts from chat list")
            
            # Reset UI after short delay
            self.after(1000, lambda: self.progress.set(0))
            self.start_btn.configure(state="normal")
            
        except Exception as e:
            import traceback
            error_details = traceback.format_exc()
            self.status_badge.set_text("ERROR", tone="danger")
            self._log(f"PRO Extraction: Failed to save CSV: {str(e)}", status="error")
            self._log(f"Error details: {error_details}", status="error")
            messagebox.showerror("Error", f"Failed to save CSV: {e}")
            self.start_btn.configure(state="normal")
            self.progress.set(0)

    def export_results(self):
        if not self.checked_results:
            return
        path = filedialog.asksaveasfilename(defaultextension=".csv", filetypes=[("CSV", "*.csv")])
        if path:
            try:
                with open(path, 'w', newline='', encoding='utf-8') as f:
                    writer = csv.DictWriter(f, fieldnames=["phone", "name", "status"])
                    writer.writeheader()
                    writer.writerows(self.checked_results)
                messagebox.showinfo("Success", "Exported successfully")
            except Exception as e:
                messagebox.showerror("Error", f"Export failed: {e}")
