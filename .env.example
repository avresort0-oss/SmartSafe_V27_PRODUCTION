# SmartSafe V27 - Environment Configuration
# Copy this file to .env and fill in your values
# Node server reads .env from project root or whatsapp-server/.env.

# ============================================
# Minimal Safe Example (Recommended)
# ============================================
# Keep API access locked down and scoped to your UI origin.
SMARTSAFE_NODE_HOST=127.0.0.1
SMARTSAFE_NODE_PORT=4000
SMARTSAFE_API_KEY=CHANGE_ME_LONG_RANDOM
SMARTSAFE_REQUIRE_API_KEY=true
# Comma separated list (e.g. http://localhost:3000,http://127.0.0.1:3000).
SMARTSAFE_CORS_ORIGINS=http://localhost:3000

# ============================================
# LiteLLM Configuration (Recommended)
# ============================================
# Enable LiteLLM proxy (set true when configured)
LITELLM_ENABLED=false
LITELLM_PROXY_URL=http://localhost:4000

# LiteLLM API Key (get from https://litellm.ai/)
LITELLM_API_KEY=

# Model configuration (in priority order)
LITELLM_MODEL=grok-fast
LITELLM_FALLBACK_MODEL=blackbox-pro

# ============================================
# Direct API Keys (Alternative to LiteLLM)
# ============================================
# Blackbox AI (primary)
BLACKBOX_API_KEY=

# OpenAI (fallback)
OPENAI_API_KEY=

# OpenRouter (for minimax models)
OPENROUTER_API_KEY=

# ============================================
# SmartSafe Application Settings
# ============================================
# Node.js Server
# (See Minimal Safe Example above for SMARTSAFE_NODE_* and security settings.)

# API Timeout (seconds)
SMARTSAFE_API_TIMEOUT=30

# ============================================
# Feature Flags
# ============================================
# Set to "true" to use Blackbox API directly (bypasses LiteLLM)
USE_BLACKBOX_API=false

# AI Model (used when not using LiteLLM)
AI_MODEL=gpt-3.5-turbo
AI_API_URL=https://api.openai.com/v1
